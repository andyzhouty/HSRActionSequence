{
  "name": "hsractionsequence",
  "private": true,
  "version": "2026.7.12-2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "wails:frontend-build": "node scripts/sync-appicon.cjs && pnpm build",
    "test": "vitest run",
    "lint": "biome check src/ tests/",
    "format:check": "biome format --write src/ tests/",
    "format:ci": "biome ci src/ tests/",
    "check": "pnpm exec tsc --noEmit && pnpm lint && pnpm test",
    "check:docs": "node scripts/checkDocPaths.mjs",
    "docs:merge": "node scripts/merge-docs.mjs",
    "preview": "vite preview",
    "wails": "wails"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "modern-screenshot": "^4.7.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}

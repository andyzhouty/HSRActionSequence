# Windows-only repository:
# keep checked-out text files as CRLF to reduce line-ending churn/warnings.
* text=auto eol=crlf

# Common binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
*.exe binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.zip binary
*.pdf binary
